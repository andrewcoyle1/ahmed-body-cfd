FoamFile
{
    version   2.0;
    format    ascii;
    class     dictionary;
    location  "system";
    object    generateBoundaryLayersDict;
}

// Two-pass BL strategy: cartesianMesh builds the Cartesian background mesh,
// then generateBoundaryLayers inserts prismatic layers in a separate step.
// This avoids the 1200:1 aspect-ratio limit in cfMesh's in-mesh BL optimizer.

boundaryLayers
{
    patchBoundaryLayers
    {
        // Single ahmed_body patch covers all body surfaces including slant,
        // underbody, and diffuser — allowDiscontinuity permits layer count
        // to reduce at concave junctions (e.g. underbody corners at low
        // ride heights) without failing the mesh.
        "ahmed_body"
        {
            nLayers                  5;
            thicknessRatio            1.2;
            maxFirstLayerThickness    1e-3;
            allowDiscontinuity        1;
        }

        "ground"
        {
            nLayers                  5;
            thicknessRatio            1.2;
            maxFirstLayerThickness    1e-3;
            allowDiscontinuity        0;
        }
    }

    optimiseLayer 1;

    optimisationParameters
    {
        nSmoothNormals       3;
        maxNumIterations     5;
        featureSizeFactor    0.4;
        reCalculateNormals   1;
        relThicknessTol      0.1;
    }
}
