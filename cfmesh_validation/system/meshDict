FoamFile
{
    version   2.0;
    format    ascii;
    class     dictionary;
    location  "system";
    object    meshDict;
}

// ─── Input surface ────────────────────────────────────────────────────────────
// Combined STL: ahmed_body + 6 named domain boundary faces.
// Generated by generate_domain_stl.py from the FreeCAD body STL.
surfaceFile "constant/triSurface/ahmed_domain.stl";

// ─── Global cell size limits (L2 medium mesh, target ≈ 1.4 M cells) ──────────
// Note: cfMesh rounds specified cell sizes to the nearest octree level (powers
// of 2 × root cell), so actual sizes are slightly coarser than requested.
// These values are calibrated to produce ≈ 1.4 M cells in the Cartesian
// background mesh BEFORE boundary layer insertion.
maxCellSize 0.200;
minCellSize 0.005;

// ─── Volume refinement zones ──────────────────────────────────────────────────
// Four nested boxes + one nose sphere; each step is a 2:1 size ratio so
// cfMesh never produces an abrupt cell-size jump across zone boundaries.
objectRefinements
{
    // Zone 1 — far wake: coarsen quickly downstream
    farWake
    {
        type     box;
        cellSize 0.100;
        centre   ( 7.5  0.0  0.40 );
        lengthX  13.0;
        lengthY   1.20;
        lengthZ   0.80;
    }

    // Zone 2 — near wake + underbody: recirculation bubble, diffuser exit
    // 0.050m = exact octree level 10 (root 51.2m / 1024).
    // This allows nearWake to sit at level 10, so farWake can sit at level 9
    // instead of being dragged to level 10 by the 2:1 cascade.
    nearWake
    {
        type     box;
        cellSize 0.050;
        centre   ( 1.85  0.0  0.275 );
        lengthX   4.30;
        lengthY   0.70;
        lengthZ   0.55;
    }

    // Zone 3 — body proximity: 150 mm margin around body envelope at all
    // design-space extremes (ride_height 40–90 mm, slant 20–45°)
    // 0.025m = exact octree level 11 (root 51.2m / 2048).
    bodyProximity
    {
        type     box;
        cellSize 0.025;
        centre   ( 0.525  0.0  0.22 );
        lengthX   1.45;
        lengthY   0.60;
        lengthZ   0.44;
    }

    // noseSphere removed: ahmed_body surface at level 13 (6.25mm) resolves
    // all nose radii in the design space (R_min=40mm → 10 cells/quarter-arc).
    // Level 14 in a 0.25m-radius sphere was the cascade root forcing the
    // entire zone hierarchy one level finer than intended.
}

// ─── Surface patch refinement ─────────────────────────────────────────────────
// Finer resolution where physics are most sensitive; coarser where they aren't.
// ahmed_diffuser entry is present for non-zero diffuser angles; cfMesh ignores
// it silently when the patch is absent from the STL (diffuser_angle = 0°).
localRefinement
{
    "ahmed_slant"     { cellSize 0.004; }
    "ahmed_diffuser"  { cellSize 0.004; }
    "ahmed_body"      { cellSize 0.006; }
    "ahmed_underbody" { cellSize 0.010; }
}

// ─── Boundary layers ──────────────────────────────────────────────────────────
// BL insertion is intentionally omitted here.
// The 5e-6 m first layer / 6mm volume cell = 1200:1 aspect ratio exceeds
// cfMesh's in-mesh BL optimizer limit. Use generateBoundaryLayers as a
// separate pass after cartesianMesh completes (see generateBoundaryLayersDict).

// ─── Mesh quality targets ─────────────────────────────────────────────────────
// maxNonOrthogonality 65 → nNonOrthogonalCorrectors can be reduced from 3 to 1
// in all downstream solvers (≈ 20% wall-time saving per timestep).
// snappyHexMesh averaged 64–72° at L2; cfMesh Cartesian core is ≈ 0°,
// and the optimizer targets only the BL-to-volume transition cells.
meshQualitySettings
{
    maxNonOrthogonality   65;
    maxSkewness            4;
    minVolume          1e-15;
}

// ─── Patch renaming and type assignment ───────────────────────────────────────
// The STL solid names become patch names directly. This section just sets
// the OpenFOAM patch type for each so the boundary file is solver-ready.
renameBoundary
{
    defaultName   defaultFaces;
    defaultType   wall;

    newPatchNames
    {
        "ahmed_slant"
        {
            newName   ahmed_slant;
            type      wall;
        }

        "ahmed_diffuser"
        {
            newName   ahmed_diffuser;
            type      wall;
        }

        "ahmed_body"
        {
            newName   ahmed_body;
            type      wall;
        }

        "ahmed_underbody"
        {
            newName   ahmed_underbody;
            type      wall;
        }

        "inlet"
        {
            newName   inlet;
            type      patch;
        }

        "outlet"
        {
            newName   outlet;
            type      patch;
        }

        "ground"
        {
            newName   ground;
            type      wall;
        }

        "top"
        {
            newName   top;
            type      patch;
        }

        "side1"
        {
            newName   side1;
            type      patch;
        }

        "side2"
        {
            newName   side2;
            type      patch;
        }
    }
}
