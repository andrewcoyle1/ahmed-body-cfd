# ── Large case data directories ───────────────────────────────────────────────
des_cases/
openfoam_cases/
sandbox/
cfmesh_test/
mesh_test_gmsh/

# ── OpenFOAM mesh output (any depth) ─────────────────────────────────────────
**/constant/polyMesh/
**/constant/extendedFeatureEdgeMesh/

# ── Generated STLs (regenerated by generate_domain_stl.py) ───────────────────
**/triSurface/ahmed_body.stl
**/triSurface/ahmed_body_raw.stl
**/triSurface/ahmed_domain.stl
**/triSurface/*.eMesh
**/triSurface/*.extendedFeatureEdgeMesh
**/triSurface/ahmed_body_hq.*

# ── Parallel decomposition ────────────────────────────────────────────────────
**/processor*/

# ── Solver time directories (keep 0/ for initial conditions) ─────────────────
**/[1-9]*/
**/*.[0-9]*/

# ── mesh_convergence initialised fields (large mapped snapshots; use _field_init/) ──
mesh_convergence/*/0/

# ── Solver output ─────────────────────────────────────────────────────────────
**/postProcessing/
**/VTK/
**/sets/
**/probes/

# ── Logs ──────────────────────────────────────────────────────────────────────
log.*
*.log

# ── ParaView ──────────────────────────────────────────────────────────────────
*.pvsm

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.ipynb_checkpoints/

# ── LaTeX build artifacts ─────────────────────────────────────────────────────
cfd_report/*.aux
cfd_report/*.bbl
cfd_report/*.blg
cfd_report/*.fdb_latexmk
cfd_report/*.fls
cfd_report/*.out
cfd_report/*.synctex.gz
cfd_report/*.toc
cfd_report/*.lof
cfd_report/*.lot
cfd_report/*.pdf

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── Generated study output ────────────────────────────────────────────────────
doe_output/
des_output/
results/
# macOS case-insensitive: exempt the LaTeX Results section from the results/ rule
!cfd_report/[Rr]esults/
design_matrix.csv
*.pkl
*.json
